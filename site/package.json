{
  "name": "site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "devs": "HTTPS=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:build": "DEPLOY=true vite build && cp dist/index.html dist/404.html",
    "deploy": "pnpm run deploy:build && gh-pages -d dist -t",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "^7.15.1",
    "smplr": "link:..",
    "soundfont2": "^0.5.0",
    "tonal": "^6.4.3",
    "webmidi": "^3.1.16"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "6.0.3",
    "vite": "^8.0.13"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.28.0"
}
