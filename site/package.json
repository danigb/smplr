{
  "name": "site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "devs": "HTTPS=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:build": "DEPLOY=true vite build && cp dist/index.html dist/404.html",
    "deploy": "pnpm run deploy:build && gh-pages -d dist -t",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.30.0",
    "smplr": "link:..",
    "soundfont2": "^0.4.0",
    "tonal": "^6.4.3",
    "webmidi": "^3.1.16"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "5.4.5",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "^8.5.10"
    }
  },
  "packageManager": "pnpm@10.28.0"
}
